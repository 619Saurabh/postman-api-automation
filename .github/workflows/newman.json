name: Run Postman API Tests

on:
  push:
    branches:
      - '*'

jobs:
  api-test:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout Repository
        uses: actions/checkout@v3

      - name: Setup Node
        uses: actions/setup-node@v3
        with:
          node-version: 18

      - name: Install Newman
        run: npm install -g newman

      - name: Run Collection
        run: newman run FakeStoreAPI.json -e QAEnv.json