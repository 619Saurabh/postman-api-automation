  "item": [
    {
      "name": "Get All Products",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"Validate status code is 200\", ()=>\r",
              "{\r",
              "    pm.response.to.have.status(200)\r",
              "})\r",
              "\r",
              "pm.test(\"Validate response is in JSON format\", ()=>\r",
              "{\r",
              "    pm.response.to.be.json;//Validating api response to be in json format\r",
              "})\r",
              "\r",
              "//Validating response is an array\r",
              "pm.test(\"Validate response is an array\", ()=>{\r",
              "    pm.expect(Array.isArray(jsonData)).to.be.true;\r",
              "})\r",
              "\r",
              "pm.test(\"Validate products count is 20\", ()=>{\r",
              "    pm.expect(jsonData.length).to.equal(20)//so in order to validate the count we have to use the method length\r",
              "})\r",
              "\r",
              "\r",
              "//Validate count of products should be more than 0\r",
              "pm.test(\"Validate count of products should be greater than 0\", ()=>{\r",
              "    pm.expect(jsonData.length).to.be.greaterThan(0)\r",
              "})\r",
              "\r",
              "\r",
              "pm.test(\"Validate each product has mandatory properties\", ()=>{\r",
              "    jsonData.forEach((product) => {\r",
              "        pm.expect(product).to.have.property('id');\r",
              "        pm.expect(product).to.have.property('title');\r",
              "        pm.expect(product).to.have.property('price');\r",
              "        pm.expect(product).to.have.property('description'); \r",
              "        pm.expect(product).to.have.property('category');\r",
              "        pm.expect(product).to.have.property('image');\r",
              "        pm.expect(product.rating).to.have.property('rate');\r",
              "        pm.expect(product.rating).to.have.property('count');\r",
              "    })\r",
              "})\r",
              "\r",
              "\r",
              "pm.test(\"Validate data type of each property of a product\", () => {\r",
              "    jsonData.forEach((product) => {\r",
              "        pm.expect(product.id).to.be.a('number');\r",
              "        pm.expect(product.title).to.be.a('string');\r",
              "        pm.expect(product.price).to.be.a('number');\r",
              "        pm.expect(product.description).to.be.a('string');\r",
              "        pm.expect(product.category).to.be.a('string');\r",
              "        pm.expect(product.image).to.be.a('string');\r",
              "        pm.expect(product.rating).to.be.an('object');\r",
              "        pm.expect(product.rating.rate).to.be.a('number');\r",
              "        pm.expect(product.rating.count).to.be.a('number');\r",
              "    })\r",
              "})\r",
              "\r",
              "\r",
              "//To validate image is an url we will use regex\r",
              "pm.test(\"Validate image is an url\", ()=>{\r",
              "jsonData.forEach((product) => {\r",
              "    pm.expect(product.image).to.match(/^https?:\\/\\//);\r",
              "})\r",
              "})\r",
              "\r",
              "\r",
              "pm.test(\"Validate price of product should be greater than zero\", () => {\r",
              "    jsonData.forEach((product) => {\r",
              "        pm.expect(product.price).to.be.greaterThan(0);\r",
              "    })\r",
              "})\r",
              "\r",
              "\r",
              "pm.test(\"Validate price of product is within the range\", () => {\r",
              "    jsonData.forEach((product) => {\r",
              "        pm.expect(product.price).to.be.within(0, 1000);\r",
              "    })\r",
              "})\r",
              "\r",
              "\r",
              "pm.test(\"Validate category should not empty\", () => {\r",
              "    jsonData.forEach((product) => {\r",
              "        pm.expect(product.category).to.not.be.empty;\r",
              "    })\r",
              "})\r",
              "\r",
              "\r",
              "pm.test(\"Validate category belongs to allowed list\", () => {\r",
              "    var allowedCategories = [\"men's clothing\", \"women's clothing\", \"jewelery\", \"electronics\"];\r",
              "    jsonData.forEach((product) => {\r",
              "        pm.expect(product.category).to.be.oneOf(allowedCategories);\r",
              "    })\r",
              "})\r",
              "\r",
              "\r",
              "\r",
              "pm.test(\"Validate rating of each product\", () => {\r",
              "    jsonData.forEach((product) => {\r",
              "        pm.expect(product.rating).to.be.an('object');\r",
              "        pm.expect(product.rating).to.have.property('rate')\r",
              "        pm.expect(product.rating.rate).to.be.a('number')\r",
              "        pm.expect(product.rating).to.have.property('count');\r",
              "        pm.expect(product.rating.count).to.be.a('number');\r",
              "    })\r",
              "})"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
