    {
      "name": "Create a Product",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "console.log(pm.environment.get(\"productName\"))\r",
              "console.log(pm.environment.get(\"productPrice\"))\r",
              "//First and most basic validation test\r",
              "pm.test(\"Validate status code to be 201\", () => {\r",
              "    pm.response.to.have.status(201);\r",
              "})\r",
              "\r",
              "pm.test(\"Validate response body is not empty\", () => {\r",
              "    pm.expect(pm.response.json()).to.not.be.empty;\r",
              "})\r",
              "\r",
              "//Most important validation in POST request\r",
              "let requestData = pm.request.body.raw;\r",
              "let requestJSON = JSON.parse(requestData);\r",
              "console.log(requestJSON)\r",
              "\r",
              "let responseJSON = pm.response.json();\r",
              "console.log(responseJSON)\r",
              "\r",
              "pm.test(\"Validate request data matches response data\", () => {\r",
              "    pm.expect(responseJSON.title).to.be.equal(requestJSON.title);\r",
              "    pm.expect(responseJSON.price).to.eql(requestJSON.price);\r",
              "    pm.expect(responseJSON.description).to.equal(requestJSON.description);\r",
              "    pm.expect(responseJSON.category).to.equal(requestJSON.category);\r",
              "})\r",
              "\r",
              "\r",
              "//creating an environment variable productId to use it in the next request like PUT and DELETE\r",
              "//requests\r",
              "pm.environment.set(\"productID\", responseJSON.id);\r",
              "console.log(pm.environment.get(\"productID\"))"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "let randomId = Math.floor(Math.random() * 100000);\r",
              "let productName = \"Test Product \" + randomId;\r",
              "console.log(productName)\r",
              "let productPrice = Math.floor(Math.random() * 10000) + 100;\r",
              "console.log(productPrice)\r",
              "\r",
              "pm.environment.set(\"productName\", productName);\r",
              "pm.environment.set(\"productPrice\", productPrice);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"title\": \"{{productName}}\",\r\n  \"price\": \"{{productPrice}}\",\r\n  \"description\": \"Classic\",\r\n  \"category\": \"Premium\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseURL}}/products",
          "host": [
            "{{baseURL}}"
          ],
          "path": [
            "products"
          ]
        }
      },
      "response": []
